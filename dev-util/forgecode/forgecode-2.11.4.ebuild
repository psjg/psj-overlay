# Eclasses to inherit from
inherit cargo git-r3
# Meta data for emerge and eix etc.
DESCRIPTION="Model-agnostic AI coding agent"
HOMEPAGE="https://forgecode.dev https://github.com/tailcallhq/forgecode"
SRC_URI="
	https://github.com/tailcallhq/forgecode/archive/v${PV}.tar.gz
		-> ${P}.tar.gz
	${CARGO_CRATE_URIS}
"

LICENSE="Apache-2.0"
# Dependent crate licenses
# calculated by `pycargoebuild'
LICENSE+="
	Apache-2.0 BSD Boost-1.0 CC0-1.0 CDLA-Permissive-2.0 GPL-3+ ISC MIT
	MPL-2.0 Unicode-3.0 ZLIB
"

# Note(psj): just one slot
SLOT="0"
KEYWORDS="~amd64"

# Note(psj): Upstream enables telemetry by default; this flag allows opting in.
# See: https://github.com/tailcallhq/forgecode (FORGE_TRACKER env var)
IUSE="telemetry"

BDEPEND="dev-libs/protobuf"

RUST_MIN_VER="1.92"

src_unpack() {
	cargo_src_unpack
}

src_compile() {
    APP_VERSION="${PV}" cargo_src_compile
}

src_install() {
	cargo_src_install --path crates/forge_main

	# NOTE(psj): run this if the telemtry use flag is set.
	if ! use telemetry; then
		echo "FORGE_TRACKER=false" > "${T}/99forgecode"
		doenvd "${T}/99forgecode"
	fi
}

pkg_postinst() {
	# NOTE(psj): Warn the user if telemetry was set.
	if use telemetry; then
		ewarn "Telemetry is enabled. ForgeCode will send usage data including"
		ewarn "git user emails and SSH directory information to upstream."
		ewarn "Rebuild with USE=-telemetry to disable."
	fi
}
